# ── 天宫 Tiangong 环境变量配置 ──────────────────────────────────

# ── 管理员账号（必填）───────────────────────────────────────────
# 部署后使用此账号密码登录
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ── 数据库（MySQL）─────────────────────────────────────────────
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://root:password@localhost:3306/tiangong

# ── JWT 密钥（用于认证令牌签名）────────────────────────────────
# 建议修改为随机长字符串，不修改也能运行
APP_SECRET=tiangong-secret-key-change-me-in-production

# ── 前端（Vite 暴露到浏览器）───────────────────────────────────
VITE_APP_ID=tiangong-local

# ── OAuth（可选，留空则使用内置认证）──────────────────────────
# 如果你需要连接 Kimi OAuth，填写以下配置
# VITE_KIMI_AUTH_URL=
# KIMI_AUTH_URL=
# KIMI_OPEN_URL=
# OWNER_UNION_ID=
